<Page
    x:Class="CryptoTax2026.SplashScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid Background="White">
        <Border Padding="40">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <!-- App Logo/Image with fallback -->
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                        CornerRadius="12" 
                        Width="160" 
                        Height="160"
                        HorizontalAlignment="Center">
                    <Grid>
                        <!-- Image (if available) -->
                        <Image Source="Assets/AppSplash.png" 
                               Stretch="Uniform" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               Margin="20"/>
                        <!-- Fallback text if image not available -->
                        <TextBlock Text="CryptoTax" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- App name and version -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="CryptoTax2026" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="UK Capital Gains Tax Calculator" 
                               FontSize="14" 
                               Opacity="0.7" 
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loading indicator -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Loading..." 
                               FontSize="12" 
                               Opacity="0.6" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
