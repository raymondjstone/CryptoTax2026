<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="CryptoTax2026"
           Manufacturer="CryptoTax2026"
           Version="$(var.ProductVersion)"
           UpgradeCode="B7A5F5E1-2D8C-4F9A-8E3D-1A2B3C4D5E6F"
           Compressed="yes">

    <Icon Id="CryptoTaxIcon" SourceFile="$(var.SourceDir)\Assets\AppIcon.ico" />

    <!-- Embed the cabinet inside the MSI so the installer is a single file -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Automatically remove older versions on upgrade -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of CryptoTax2026 is already installed." />

    <Feature Id="ProductFeature" Title="CryptoTax2026" Level="1">
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentGroupRef Id="ApplicationShortcuts" />
    </Feature>

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="CryptoTax2026" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="CryptoTax2026" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
  </Package>

  <Fragment>
    <ComponentGroup Id="ApplicationShortcuts">
      <Component Id="ApplicationShortcut" Directory="ApplicationProgramsFolder">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="CryptoTax2026"
                  Description="UK Crypto Capital Gains Tax Calculator"
                  Target="[INSTALLFOLDER]CryptoTax2026.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="CryptoTaxIcon" />
        <RemoveFolder Id="CleanUpShortCuts" Directory="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\CryptoTax2026"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <Component Id="DesktopShortcut" Directory="DesktopFolder">
        <Shortcut Id="ApplicationDesktopShortcut"
                  Name="CryptoTax2026"
                  Description="UK Crypto Capital Gains Tax Calculator"
                  Target="[INSTALLFOLDER]CryptoTax2026.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="CryptoTaxIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\CryptoTax2026"
                       Name="desktop_shortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>