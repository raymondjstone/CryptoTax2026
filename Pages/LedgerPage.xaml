<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.LedgerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="All Ledger Entries" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,4" />

        <!-- Filters -->
        <Border Grid.Row="1" Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                CornerRadius="6" Padding="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox x:Name="AssetFilter" Header="Asset" Width="130"
                          PlaceholderText="All" SelectionChanged="Filter_Changed">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="TypeFilter" Header="Type" Width="130"
                          PlaceholderText="All" SelectionChanged="Filter_Changed">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox x:Name="SourceFilter" Header="Source" Width="130"
                          PlaceholderText="All" SelectionChanged="Filter_Changed">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox x:Name="RefIdFilter" Header="Ref ID" PlaceholderText="Search..." Width="160"
                         TextChanged="RefIdFilter_TextChanged" />
                <Button Content="Clear Filters" VerticalAlignment="Bottom"
                        Click="ClearFilters_Click" />
                <TextBlock x:Name="FilterStatusText" VerticalAlignment="Bottom" Opacity="0.7"
                           Margin="12,0,0,0" Padding="0,0,0,6" />
            </StackPanel>
        </Border>

        <!-- Ledger list -->
        <ListView Grid.Row="2" x:Name="LedgerList" SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="LedgerList_ItemClick">
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Source" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Asset" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Type" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="SubType" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="5" Text="Amount" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="6" Text="Fee" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="7" Text="GBP Rate" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="8" Text="Rate Date" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="9" Text="Balance" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="10" Text="Ref ID" FontWeight="SemiBold" />
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" />
                        <TextBlock Grid.Column="1" Text="{Binding Source}" Opacity="0.7" />
                        <TextBlock Grid.Column="2" Text="{Binding Asset}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="{Binding Type}" />
                        <TextBlock Grid.Column="4" Text="{Binding SubType}" Opacity="0.7" />
                        <TextBlock Grid.Column="5" Text="{Binding AmountFormatted}" Foreground="{Binding AmountColor}" />
                        <TextBlock Grid.Column="6" Text="{Binding FeeFormatted}" Opacity="0.7" />
                        <TextBlock Grid.Column="7" Text="{Binding GbpRateFormatted}" Opacity="0.7" FontSize="11" />
                        <TextBlock Grid.Column="8" Text="{Binding RateDateFormatted}" Opacity="0.7" FontSize="11" />
                        <TextBlock Grid.Column="9" Text="{Binding BalanceFormatted}" Opacity="0.7" />
                        <TextBlock Grid.Column="10" Text="{Binding RefId}" Opacity="0.5" FontSize="11"
                                   TextTrimming="CharacterEllipsis" IsTextSelectionEnabled="True" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Grid.Row="2" Text="Click an entry to split it into multiple transactions."
                   Opacity="0.5" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,4" />
    </Grid>
</Page>
