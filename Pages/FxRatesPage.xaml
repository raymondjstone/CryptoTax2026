<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.FxRatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="1200" HorizontalAlignment="Left">

            <TextBlock Text="FX Rate Cache" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Name="CachePathText" Opacity="0.7" />

            <TextBlock x:Name="SummaryText" Margin="0,4,0,0" />

            <!-- Rates table -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- Header -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pair" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Points" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Earliest" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Latest" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="Latest Rate" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="5" Text="Cached" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="6" Text="Source" FontWeight="SemiBold" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,4" />

                    <ListView x:Name="RatesListView"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding PairName}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DataPointsFormatted}" />
                                    <TextBlock Grid.Column="2" Text="{Binding EarliestFormatted}" />
                                    <TextBlock Grid.Column="3" Text="{Binding LatestFormatted}" />
                                    <TextBlock Grid.Column="4" Text="{Binding RateFormatted}" />
                                    <TextBlock Grid.Column="5" Text="{Binding OnDiskLabel}" />
                                    <TextBlock Grid.Column="6" Text="{Binding DataSource}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Rate Data Explorer -->
            <TextBlock Text="Rate Data Explorer" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Browse individual rate data points for any pair." Opacity="0.7" TextWrapping="Wrap" />

            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="6" Padding="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ComboBox x:Name="RateExplorerPairFilter" Header="Pair" Width="200"
                              PlaceholderText="Select pair" SelectionChanged="RateExplorerPair_Changed">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding}" /></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock x:Name="RateExplorerStatus" VerticalAlignment="Bottom" Opacity="0.7"
                               Padding="0,0,0,6" />
                </StackPanel>
            </Border>

            <ListView x:Name="RateExplorerList" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="400">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Date"    FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Open"    FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="High"    FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Low"     FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Close"   FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Average" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Source"  FontWeight="SemiBold" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" />
                            <TextBlock Grid.Column="1" Text="{Binding OpenFormatted}" />
                            <TextBlock Grid.Column="2" Text="{Binding HighFormatted}" />
                            <TextBlock Grid.Column="3" Text="{Binding LowFormatted}" />
                            <TextBlock Grid.Column="4" Text="{Binding CloseFormatted}" />
                            <TextBlock Grid.Column="5" Text="{Binding AverageFormatted}" />
                            <TextBlock Grid.Column="6" Text="{Binding SourceFormatted}" Opacity="0.7" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Manual Rate Overrides -->
            <TextBlock Text="Manual Rate Overrides" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Add dated GBP rates for assets where no data could be downloaded. Multiple entries per asset are interpolated like real market rates." Opacity="0.7" TextWrapping="Wrap" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">

                    <!-- Add override entry -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBox x:Name="ManualAssetBox"
                                 Header="Pair (e.g. BTCGBP)"
                                 PlaceholderText="e.g. BTCGBP" Width="160" />
                        <CalendarDatePicker x:Name="ManualDatePicker"
                                            Header="Date" PlaceholderText="Pick a date"
                                            Width="220" />
                        <TextBox x:Name="ManualRateBox"
                                 Header="GBP Rate per unit"
                                 PlaceholderText="e.g. 0.00042" Width="180" />
                        <Button x:Name="AddOverrideBtn"
                                Content="Add Rate"
                                VerticalAlignment="Bottom"
                                Click="AddOverride_Click" />
                    </StackPanel>

                    <InfoBar x:Name="OverrideInfoBar" IsOpen="False" IsClosable="True" />

                    <!-- Existing overrides list -->
                    <StackPanel x:Name="ManualOverridesPanel" Spacing="4" />

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
