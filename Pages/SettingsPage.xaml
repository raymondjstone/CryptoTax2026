<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="800" HorizontalAlignment="Left">

            <TextBlock Text="Kraken API Settings" Style="{StaticResource TitleTextBlockStyle}" />
            <InfoBar x:Name="InfoMessage" IsOpen="False" />

            <TextBlock Text="You need a Kraken API key with 'Query Ledger/Trade Data' permission. Create one at kraken.com > Security > API."
                       TextWrapping="Wrap" Opacity="0.7" />

            <TextBox x:Name="ApiKeyBox" Header="API Key" PlaceholderText="Enter your Kraken API key"
                     Width="500" HorizontalAlignment="Left" />

            <PasswordBox x:Name="ApiSecretBox" Header="API Secret" PlaceholderText="Enter your Kraken API secret"
                         Width="500" HorizontalAlignment="Left" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="SaveCredentialsBtn" Content="Save Credentials" Style="{StaticResource AccentButtonStyle}"
                        Click="SaveCredentials_Click" />
                <Button x:Name="TestConnectionBtn" Content="Test Connection"
                        Click="TestConnection_Click" />
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <!-- ========== LEDGER ========== -->
            <TextBlock Text="Ledger Data" Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel x:Name="TradeInfoPanel" Spacing="4">
                <TextBlock x:Name="TradeStatusText" Text="No trades downloaded yet." />
                <TextBlock x:Name="TradeFileDate" Text="" Opacity="0.6" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="DownloadBtn" Content="Download Ledger"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="DownloadTrades_Click" />
                <Button x:Name="ResetBtn" Content="Reset &amp; Re-download All"
                        Click="ResetTrades_Click" />
            </StackPanel>
            <TextBlock x:Name="ResumeInfoText" Text="" Opacity="0.6" FontStyle="Italic" />

            <ProgressBar x:Name="DownloadProgress" IsIndeterminate="False" Visibility="Collapsed"
                         Width="500" HorizontalAlignment="Left" />
            <TextBlock x:Name="DownloadStatusText" Text="" Visibility="Collapsed" />

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <!-- ========== FX RATES ========== -->
            <TextBlock Text="FX Rate Data" Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel x:Name="FxInfoPanel" Spacing="4">
                <TextBlock x:Name="FxStatusText" Text="No FX rates loaded." />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="FxDownloadBtn" Content="Download FX Rates"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="DownloadFxRates_Click" />
                <Button x:Name="FxResetAndDownloadBtn" Content="Reset &amp; Re-download FX Rates"
                        Click="ResetAndDownloadFxRates_Click" />
            </StackPanel>
            <TextBlock x:Name="FxInfoNote" Text="Downloads exchange rates for every asset in your ledger. Requires ledger data first."
                       Opacity="0.6" FontStyle="Italic" TextWrapping="Wrap" />

            <ProgressBar x:Name="FxProgress" IsIndeterminate="False" Visibility="Collapsed"
                         Width="500" HorizontalAlignment="Left" />
            <TextBlock x:Name="FxProgressText" Text="" Visibility="Collapsed" />

            <!-- ========== FX RATE CALCULATION METHOD ========== -->
            <StackPanel Spacing="8" Margin="0,12,0,0">
                <TextBlock Text="Exchange Rate Calculation Method (HMRC Compliance)" FontWeight="SemiBold" FontSize="14" />
                <TextBlock Text="Choose how exchange rates are calculated from OHLC data for tax calculations:"
                           Opacity="0.7" TextWrapping="Wrap" FontSize="12" />
                <ComboBox x:Name="FxRateTypeSelector" Header="Rate Calculation Method" Width="400" HorizontalAlignment="Left"
                          SelectionChanged="FxRateTypeSelector_Changed">
                    <ComboBoxItem Content="Daily Average (Default)" Tag="Average" ToolTipService.ToolTip="Average of daily high and low prices"/>
                    <ComboBoxItem Content="Daily Open" Tag="Open" ToolTipService.ToolTip="First trading price of the day"/>
                    <ComboBoxItem Content="Daily High" Tag="High" ToolTipService.ToolTip="Highest trading price of the day"/>
                    <ComboBoxItem Content="Daily Low" Tag="Low" ToolTipService.ToolTip="Lowest trading price of the day"/>
                    <ComboBoxItem Content="Daily Close" Tag="Close" ToolTipService.ToolTip="Last trading price of the day"/>
                </ComboBox>
                <Border Background="#FFF3CD" 
                        CornerRadius="6" Padding="12" Margin="0,8,0,0"
                        BorderBrush="#FFEAA7" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="⚠️ IMPORTANT: Consistency Required" FontWeight="SemiBold" FontSize="12" 
                                   Foreground="#856404" />
                        <TextBlock Text="Once you select a rate calculation method, you MUST use it consistently across all transactions and tax years. Changing methods mid-year or between years may invalidate your tax calculations for HMRC purposes."
                                   TextWrapping="Wrap" FontSize="11" 
                                   Foreground="#856404" />
                        <HyperlinkButton Content="📖 HMRC Guidance: Crypto23000 - Exchange Rates" 
                                         NavigateUri="https://www.gov.uk/hmrc-internal-manuals/cryptoassets-manual/crypto23000"
                                         FontSize="11" Padding="0" Margin="0,4,0,0" 
                                         Foreground="#0066CC" />
                    </StackPanel>
                </Border>
                <TextBlock Text="All methods shown above are acceptable to HMRC. The choice depends on your preference and circumstances, but must be applied consistently."
                           Opacity="0.6" FontStyle="Italic" TextWrapping="Wrap" FontSize="11" />
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <!-- ========== DATA FRESHNESS ========== -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="Data Freshness" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock x:Name="LedgerFreshnessText" Text="" Opacity="0.7" />
                    <TextBlock x:Name="FxFreshnessText" Text="" Opacity="0.7" />
                    <TextBlock x:Name="FreshnessWarningText" Text="" Foreground="Orange" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- ========== SUMMARY ========== -->
            <TextBlock Text="Ledger Summary" Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel x:Name="TradeSummaryPanel" Spacing="4">
                <TextBlock x:Name="TotalTradesText" Text="" />
                <TextBlock x:Name="DateRangeText" Text="" />
                <TextBlock x:Name="TaxYearsText" Text="" />
                <TextBlock x:Name="AssetsText" Text="" TextWrapping="Wrap" />
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox x:Name="ThemeSelector" Header="Theme" Width="160"
                          SelectionChanged="ThemeSelector_Changed">
                    <ComboBoxItem Content="System Default" Tag="Default" />
                    <ComboBoxItem Content="Light" Tag="Light" />
                    <ComboBoxItem Content="Dark" Tag="Dark" />
                </ComboBox>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <TextBlock Text="Data Location" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="DataPathText" Text="" IsTextSelectionEnabled="True" Opacity="0.7" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Change Data Folder..." Click="ChangeDataFolder_Click" />
                <Button x:Name="ResetDataFolderBtn" Content="Reset to Default" Click="ResetDataFolder_Click" Visibility="Collapsed" />
            </StackPanel>
            <TextBlock Text="Set a custom path (e.g. OneDrive folder) to sync settings across devices. Ledger and FX cache stay local."
                       Opacity="0.6" TextWrapping="Wrap" FontSize="12" />

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <!-- ========== BACKUP / RESTORE ========== -->
            <TextBlock Text="Backup &amp; Restore" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="Export all settings, manual entries, cost overrides, and notes to a single JSON file. Restore from a previous backup."
                       TextWrapping="Wrap" Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Export Backup" Click="ExportBackup_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Restore from Backup" Click="RestoreBackup_Click" />
            </StackPanel>
            <TextBlock x:Name="BackupStatusText" Text="" Opacity="0.7" />

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <!-- ========== AUDIT LOG ========== -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Audit Log" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBox x:Name="AuditSearchBox" PlaceholderText="Search..." Width="200" VerticalAlignment="Center"
                         TextChanged="AuditSearch_TextChanged" />
                <Button Content="Export CSV" Click="ExportAuditLog_Click" VerticalAlignment="Center" />
                <Button Content="Clear Log" Click="ClearAuditLog_Click" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Records key actions for your records." Opacity="0.7" />
            <TextBlock x:Name="AuditLogCountText" Text="" Opacity="0.6" FontSize="12" />
            <ListView x:Name="AuditLogList" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="300">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Timestamp" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Action" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Detail" FontWeight="SemiBold" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding TimestampFormatted}" Opacity="0.7" />
                            <TextBlock Grid.Column="1" Text="{Binding Action}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="{Binding Detail}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" />

            <!-- ========== SUPPORT ========== -->
            <TextBlock Text="Support" Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock Text="If you find this app useful, consider buying me a coffee!" Opacity="0.7" />
            <HyperlinkButton Content="☕  Buy Me a Coffee" NavigateUri="https://buymeacoffee.com/raymondjstone" />

        </StackPanel>
    </ScrollViewer>
</Page>
