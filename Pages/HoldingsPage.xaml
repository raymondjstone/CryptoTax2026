<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.HoldingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="1100" HorizontalAlignment="Left">

            <TextBlock Text="Current Holdings &amp; Section 104 Pools" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Shows the final Section 104 pool state after all disposals have been processed. Quantity and average cost reflect the current holding."
                       TextWrapping="Wrap" Opacity="0.7" />

            <TextBlock x:Name="UnrealisedSummaryText" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,4" />

            <!-- Holdings list -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Holdings &amp; Pool Summary" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                        <Button x:Name="HoldingsCollapseBtn" Grid.Column="1" Content="▲" Click="HoldingsCollapse_Click" Padding="8,4" />
                    </Grid>
                    <StackPanel x:Name="HoldingsContent" Spacing="8">
                        <!-- Column header -->
                        <Grid Padding="8,4,48,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="60" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Asset" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Quantity" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Pooled Cost" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Est. Value" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Unrealised G/L" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Avg Cost/Unit" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="G/L %" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="7" Text="Acqs" FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl x:Name="PoolsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Expander.Header>
                                            <Grid Padding="8,2" ColumnSpacing="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Asset}" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{Binding QuantityFormatted}" />
                                                <TextBlock Grid.Column="2" Text="{Binding PooledCostFormatted}" />
                                                <TextBlock Grid.Column="3" Text="{Binding EstValueFormatted}" />
                                                <TextBlock Grid.Column="4" Text="{Binding UnrealisedGainFormatted}" Foreground="{Binding GainColor}" />
                                                <TextBlock Grid.Column="5" Text="{Binding AvgCostFormatted}" Opacity="0.7" />
                                                <TextBlock Grid.Column="6" Text="{Binding GainPercentFormatted}" Foreground="{Binding GainColor}" />
                                                <TextBlock Grid.Column="7" Text="{Binding AcquisitionCount}" Opacity="0.7" />
                                            </Grid>
                                        </Expander.Header>
                                        <!-- Drill-down: pool acquisition history -->
                                        <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="4" Padding="12" Margin="0,4">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Section 104 Pool — Acquisition History"
                                                           FontWeight="SemiBold" FontSize="12" Opacity="0.8" />
                                                <Grid Padding="4,2" ColumnSpacing="8"
                                                      Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Date" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="1" Text="Type" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="2" Text="Quantity" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="3" Text="Cost (GBP)" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="4" Text="Cost/Unit" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="5" Text="Ref" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding History}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Padding="4,2" ColumnSpacing="8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="100" />
                                                                    <ColumnDefinition Width="90" />
                                                                    <ColumnDefinition Width="140" />
                                                                    <ColumnDefinition Width="120" />
                                                                    <ColumnDefinition Width="120" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="1" Text="{Binding TypeFormatted}" FontSize="12" Opacity="0.8" />
                                                                <TextBlock Grid.Column="2" Text="{Binding QuantityFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="3" Text="{Binding CostFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="4" Text="{Binding CostPerUnitFormatted}" FontSize="12" Opacity="0.7" />
                                                                <TextBlock Grid.Column="5" Text="{Binding RefId}" FontSize="11" Opacity="0.4"
                                                                           TextTrimming="CharacterEllipsis" IsTextSelectionEnabled="True" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Expand an asset row to view its Section 104 pool acquisition history."
                                   Opacity="0.5" FontSize="12" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
