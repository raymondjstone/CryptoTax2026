                            <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Asset" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Quantity" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Proceeds" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Cost" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Gain/Loss" FontWeight="SemiBold" />
                        </Grid>
                        <ItemsControl x:Name="BnbList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Expander.Header>
                                            <Grid Padding="0,2" ColumnSpacing="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="120" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Asset}" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="2" Text="{Binding QuantityFormatted}" />
                                                <TextBlock Grid.Column="3" Text="{Binding ProceedsFormatted}" />
                                                <TextBlock Grid.Column="4" Text="{Binding CostFormatted}" />
                                                <TextBlock Grid.Column="5" Text="{Binding GainFormatted}" Foreground="{Binding GainColor}" />
                                            </Grid>
                                        </Expander.Header>
                                        <!-- Drill-down: underlying ledger entries -->
                                        <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="4" Padding="12" Margin="0,4">
                                            <StackPanel Spacing="4">
                                                <!-- Disposal (sell) entries -->
                                                <TextBlock Text="Disposal (sell) — Kraken ledger entries"
                                                           FontWeight="SemiBold" FontSize="12" Opacity="0.8" />
                                                <Grid Padding="4,2" ColumnSpacing="8"
                                                      Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Date/Time" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="1" Text="Type" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="2" Text="Asset" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="3" Text="Amount" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="4" Text="Fee" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="5" Text="Ledger ID" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding DisposalEntries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Padding="4,2" ColumnSpacing="8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130" />
                                                                    <ColumnDefinition Width="90" />
                                                                    <ColumnDefinition Width="70" />
                                                                    <ColumnDefinition Width="160" />
                                                                    <ColumnDefinition Width="120" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Type}" FontSize="12" Opacity="0.8" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Asset}" FontSize="12" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="3" Text="{Binding AmountFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="4" Text="{Binding FeeFormatted}" FontSize="12" Opacity="0.6" />
                                                                <TextBlock Grid.Column="5" Text="{Binding LedgerId}" FontSize="11" Opacity="0.4" IsTextSelectionEnabled="True" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <!-- Acquisition (buy) entries -->
                                                <TextBlock Text="Matched reacquisition (buy, within 30 days) — Kraken ledger entries"
                                                           FontWeight="SemiBold" FontSize="12" Opacity="0.8" Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding AcquisitionDateLabel}"
                                                           FontSize="12" Opacity="0.6" FontStyle="Italic" />
                                                <Grid Padding="4,2" ColumnSpacing="8"
                                                      Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="90" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Date/Time" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="1" Text="Type" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="2" Text="Asset" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="3" Text="Amount" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="4" Text="Fee" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                    <TextBlock Grid.Column="5" Text="Ledger ID" FontSize="11" FontWeight="SemiBold" Opacity="0.7" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding AcquisitionEntries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Padding="4,2" ColumnSpacing="8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130" />
                                                                    <ColumnDefinition Width="90" />
                                                                    <ColumnDefinition Width="70" />
                                                                    <ColumnDefinition Width="160" />
                                                                    <ColumnDefinition Width="120" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Type}" FontSize="12" Opacity="0.8" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Asset}" FontSize="12" FontWeight="SemiBold" />
                                                                <TextBlock Grid.Column="3" Text="{Binding AmountFormatted}" FontSize="12" />
                                                                <TextBlock Grid.Column="4" Text="{Binding FeeFormatted}" FontSize="12" Opacity="0.6" />
                                                                <TextBlock Grid.Column="5" Text="{Binding LedgerId}" FontSize="11" Opacity="0.4" IsTextSelectionEnabled="True" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Asset P&L Breakdown -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="P&amp;L by Asset" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                        <Button x:Name="AssetPnlCollapseBtn" Grid.Column="1" Content="▲" Click="AssetPnlCollapse_Click" Padding="8,4" />
                    </Grid>
                    <StackPanel x:Name="AssetPnlContent" Spacing="8">
                        <ListView x:Name="AssetPnlList" SelectionMode="None" IsItemClickEnabled="False">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Asset" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="Disposals" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" Text="Proceeds" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="3" Text="Cost" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="4" Text="Gain/Loss" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="5" Text="% of Total" FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Asset}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ProceedsFormatted}" />
                                        <TextBlock Grid.Column="3" Text="{Binding CostFormatted}" />
                                        <TextBlock Grid.Column="4" Text="{Binding GainFormatted}" Foreground="{Binding GainColor}" />
                                        <TextBlock Grid.Column="5" Text="{Binding PercentFormatted}" Opacity="0.7" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Disposals Detail -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Margin="0,8,0,0">
                <StackPanel Spacing="8">
                    <!-- Panel header (always visible) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Individual Disposals" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Export HMRC Schedule" Click="ExportHmrcSchedule_Click"
                                VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button x:Name="DisposalsCollapseBtn" Grid.Column="2" Content="▲" Click="DisposalsCollapse_Click" Padding="8,4" />
                    </Grid>

                    <!-- Collapsible content -->
                    <StackPanel x:Name="DisposalsContent" Spacing="8">
                        <TextBlock Text="Each row is a disposal event matched using HMRC rules (same-day, bed &amp; breakfast 30-day, then Section 104 pool). Expand a row to see the underlying Kraken ledger entries."
                                   TextWrapping="Wrap" Opacity="0.7" />

                        <!-- Filter Controls -->
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="6" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="12">
