                        <Button x:Name="Sa108CollapseBtn" Grid.Column="2" Content="▲" Click="Sa108Collapse_Click" Padding="8,4" />
                    </Grid>
                    <StackPanel x:Name="Sa108Content" Spacing="8">
                        <TextBlock Text="Enter these figures on the Capital Gains Summary (SA108) page of your Self Assessment tax return."
