<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.TaxYearPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="1000" HorizontalAlignment="Left">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TaxYearTitle" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="TaxYearDateRange" Opacity="0.7" />
                </StackPanel>

                <!-- Export buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox x:Name="IncludeKrakenData" Content="Include Kraken trades" IsChecked="True" VerticalAlignment="Center" />
                    <DropDownButton Content="Export">
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Export to Excel (.xlsx)" Click="ExportExcel_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9F9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export to PDF" Click="ExportPdf_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xEA90;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export to Word (.docx)" Click="ExportWord_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A5;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Export ALL Tax Years to Excel" Click="ExportAllExcel_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </Grid>
            <InfoBar x:Name="ExportInfoBar" IsOpen="False" />

            <!-- User Input Section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Your Details for This Tax Year" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Enter your total taxable income from ALL sources and any other capital gains (non-crypto). Capital gains sit on top of all other income when determining the CGT rate, so you must include all taxable income. Scottish/Welsh taxpayers: enter your actual income — the app uses the UK-wide basic rate band for CGT (per legislation), not Scottish/Welsh income tax bands."
                               TextWrapping="Wrap" Opacity="0.7" />

                    <NumberBox x:Name="TaxableIncomeBox" Header="Total Taxable Income (employment, self-employment, pensions, savings interest, dividends, rental etc.)"
                               PlaceholderText="e.g. 45000" SpinButtonPlacementMode="Compact"
                               Minimum="0" SmallChange="1000" LargeChange="10000"
                               ValueChanged="TaxableIncome_ValueChanged"
                               Width="350" HorizontalAlignment="Left"
                               Description="Include all taxable income: wages, pensions, taxable savings interest (above your savings allowance), taxable dividends (above the £1,000 dividend allowance), rental income, and any other taxable income. Capital gains are stacked on top of this total to determine which CGT rate applies." />

                    <NumberBox x:Name="OtherGainsBox" Header="Other Capital Gains (non-crypto, e.g. shares, property)"
                               PlaceholderText="e.g. 0" SpinButtonPlacementMode="Compact"
                               Minimum="0" SmallChange="100" LargeChange="1000"
                               ValueChanged="OtherGains_ValueChanged"
                               Width="350" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- CGT Summary -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Capital Gains Tax Summary" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid ColumnSpacing="20" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                            <RowDefinition /><RowDefinition /><RowDefinition />
                            <RowDefinition /><RowDefinition /><RowDefinition />
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Number of disposals" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DisposalCountText" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Text="Total disposal proceeds" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalProceedsText" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2" Text="Total allowable costs" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TotalCostsText" FontWeight="SemiBold" />

                        <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                        <TextBlock Grid.Row="4" Text="Total gains" />
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TotalGainsText" FontWeight="SemiBold"
                                   Foreground="Green" />

                        <TextBlock Grid.Row="5" Text="Total losses" />
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TotalLossesText" FontWeight="SemiBold"
                                   Foreground="Red" />

                        <TextBlock Grid.Row="6" Text="Net gain/loss" />
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="NetGainText" FontWeight="SemiBold" />

                        <Border Grid.Row="7" Grid.ColumnSpan="2" Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                        <TextBlock Grid.Row="8" x:Name="AeaLabel" Text="Annual exempt amount" />
                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="AeaText" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="9" Text="Taxable gain (after AEA)" />
                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="TaxableGainText" FontWeight="Bold"
                                   FontSize="16" />

                        <TextBlock Grid.Row="10" x:Name="CgtRatesLabel" Opacity="0.7" />
                        <TextBlock Grid.Row="10" Grid.Column="1" />

                        <TextBlock Grid.Row="11" Text="CAPITAL GAINS TAX DUE" FontWeight="Bold" FontSize="16" />
                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="CgtDueText" FontWeight="Bold"
                                   FontSize="20" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Tax Rates Info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="Tax Rates Applied" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="BasicRateText" Opacity="0.7" />
                    <TextBlock x:Name="HigherRateText" Opacity="0.7" />
                    <TextBlock x:Name="BasicBandText" Opacity="0.7" />
                    <TextBlock x:Name="PersonalAllowanceText" Opacity="0.7" />
                    <TextBlock Text="Rates sourced from HMRC. Crypto assets are taxed as 'other assets' for CGT purposes."
                               Opacity="0.5" TextWrapping="Wrap" Margin="0,8,0,0" FontStyle="Italic" />
                    <TextBlock Text="Scottish &amp; Welsh taxpayers: CGT is a UK-wide reserved tax. The rates, annual exempt amount, basic rate band (&#163;37,700), and personal allowance (&#163;12,570) shown here are the UK-wide figures — these apply to all UK taxpayers regardless of Scottish/Welsh income tax status. Your Scottish/Welsh income tax bands only affect income tax, not CGT."
                               Opacity="0.5" TextWrapping="Wrap" Margin="0,4,0,0" FontStyle="Italic" />
                </StackPanel>
            </Border>

            <!-- Portfolio Balances - Start of Year -->
            <Border x:Name="StartBalancePanel" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="StartBalanceTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="StartBalanceTotalText" FontWeight="Bold" FontSize="14" />
                    <ListView x:Name="StartBalanceList" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="300">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Asset" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="Quantity" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="GBP Value" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Asset}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding QuantityFormatted}" />
                                    <TextBlock Grid.Column="2" Text="{Binding GbpFormatted}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Portfolio Balances - End of Year -->
            <Border x:Name="EndBalancePanel" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="EndBalanceTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="EndBalanceTotalText" FontWeight="Bold" FontSize="14" />
                    <ListView x:Name="EndBalanceList" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="300">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Asset" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="Quantity" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="GBP Value" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Asset}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding QuantityFormatted}" />
                                    <TextBlock Grid.Column="2" Text="{Binding GbpFormatted}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Warnings / Data Issues -->
            <Border x:Name="WarningsPanel" Visibility="Collapsed"
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="WarningsTitle" Grid.Column="0" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                        <Button x:Name="CopyWarningsBtn" Grid.Column="1" Content="Copy to Clipboard" Click="CopyWarnings_Click" />
                    </Grid>
                    <TextBlock Text="These issues were found during calculation. They may affect the accuracy of the results."
                               TextWrapping="Wrap" Opacity="0.7" />
                    <ListView x:Name="WarningsList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,2" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding LevelText}" FontWeight="SemiBold"
                                               Foreground="{Binding LevelColor}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Category}" Opacity="0.7" />
                                    <TextBlock Grid.Column="2" Text="{Binding DateFormatted}" Opacity="0.7" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Staking Income -->
            <Border x:Name="StakingPanel" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Staking / Dividend Income" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Staking rewards are taxed as miscellaneous income (not capital gains). This is separate from CGT."
                               TextWrapping="Wrap" Opacity="0.7" />
                    <TextBlock x:Name="StakingTotalText" FontWeight="Bold" FontSize="14" />
                    <ListView x:Name="StakingList" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="300">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="Asset" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="Amount" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="3" Text="GBP Value" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Asset}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="{Binding AmountFormatted}" />
                                    <TextBlock Grid.Column="3" Text="{Binding GbpFormatted}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- What-If Scenario (only for open tax years) -->
            <Border x:Name="WhatIfPanel" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="What If? — Hypothetical Trade Scenarios" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Add one or more hypothetical trades (buys or sells) to see how they would affect your tax liability for this year. This is a simulation only — nothing is saved."
                               TextWrapping="Wrap" Opacity="0.7" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox x:Name="WhatIfSideBox" Header="Side" Width="80" SelectedIndex="0">
                            <ComboBoxItem Content="Sell" />
                            <ComboBoxItem Content="Buy" />
                        </ComboBox>
                        <TextBox x:Name="WhatIfAssetBox" Header="Asset" PlaceholderText="e.g. XRP" Width="100" />
                        <ComboBox x:Name="WhatIfCurrencyBox" Header="Price Currency" Width="100" SelectedIndex="0">
                            <ComboBoxItem Content="USD" />
                            <ComboBoxItem Content="GBP" />
                            <ComboBoxItem Content="EUR" />
                        </ComboBox>
                        <NumberBox x:Name="WhatIfPriceBox" Header="Price Per Unit" PlaceholderText="e.g. 1.40"
                                   SpinButtonPlacementMode="Compact" Minimum="0" Width="150" />
                        <NumberBox x:Name="WhatIfQuantityBox" Header="Quantity to Sell" PlaceholderText="e.g. 2000"
                                   SpinButtonPlacementMode="Compact" Minimum="0" Width="150" />
                        <CalendarDatePicker x:Name="WhatIfDatePicker" Header="Sale Date" Width="160" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="WhatIfAddBtn" Content="Add Trade" Click="WhatIfAdd_Click"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="WhatIfCalculateBtn" Content="Calculate" Click="WhatIfCalculate_Click" IsEnabled="False" />
                        <Button x:Name="WhatIfClearBtn" Content="Clear All" Click="WhatIfClear_Click" />
                    </StackPanel>

                    <InfoBar x:Name="WhatIfInfoBar" IsOpen="False" />

                    <!-- Pending What-If Trades List -->
                    <Border x:Name="WhatIfTradesPanel" Visibility="Collapsed"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            CornerRadius="6" Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="WhatIfTradesHeader" Text="Hypothetical Trades" FontWeight="SemiBold" />
                            <ListView x:Name="WhatIfTradesList" SelectionMode="None" IsItemClickEnabled="False">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4,2" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Description}" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                    Click="WhatIfRemoveTrade_Click" Tag="{Binding Index}"
                                                    Padding="4,2" Background="Transparent" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- What-If Results -->
                    <Border x:Name="WhatIfResultsPanel" Visibility="Collapsed"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="What-If Results" FontWeight="Bold" FontSize="16" />
                            <TextBlock x:Name="WhatIfTradeDescription" TextWrapping="Wrap" Opacity="0.8" />

                            <Grid ColumnSpacing="24" RowSpacing="4" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition /><RowDefinition /><RowDefinition />
                                    <RowDefinition /><RowDefinition /><RowDefinition />
                                </Grid.RowDefinitions>

                                <!-- Header row -->
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Current" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="With Trades" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Difference" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="1" Text="Net gain/loss" />
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="WhatIfCurrentNet" />
                                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="WhatIfNewNet" />
                                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="WhatIfDiffNet" FontWeight="SemiBold" />

                                <TextBlock Grid.Row="2" Text="Taxable gain (after AEA)" />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="WhatIfCurrentTaxable" />
                                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="WhatIfNewTaxable" />
                                <TextBlock Grid.Row="2" Grid.Column="3" x:Name="WhatIfDiffTaxable" FontWeight="SemiBold" />

                                <Border Grid.Row="3" Grid.ColumnSpan="4" Height="1"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                                <TextBlock Grid.Row="4" Text="CGT due" FontWeight="Bold" />
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="WhatIfCurrentCgt" />
                                <TextBlock Grid.Row="4" Grid.Column="2" x:Name="WhatIfNewCgt" FontWeight="Bold" />
                                <TextBlock Grid.Row="4" Grid.Column="3" x:Name="WhatIfDiffCgt" FontWeight="Bold" />

                                <TextBlock Grid.Row="5" Text="Disposal details" Opacity="0.7" />
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="WhatIfTradeSummary" Opacity="0.7" TextWrapping="Wrap"
                                           Grid.ColumnSpan="3" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Disposals Detail -->
            <TextBlock Text="Individual Disposals" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Each row is a disposal event matched using HMRC rules (same-day, bed &amp; breakfast 30-day, then Section 104 pool)."
                       TextWrapping="Wrap" Opacity="0.7" />

            <!-- Filter Controls -->
            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ComboBox x:Name="DisposalAssetFilter" Header="Filter by Asset" Width="150"
                              PlaceholderText="All Assets" SelectionChanged="DisposalAssetFilter_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button x:Name="ClearFilterBtn" Content="Clear Filter" VerticalAlignment="Bottom"
                            Click="ClearDisposalFilter_Click" />
                    <TextBlock x:Name="FilterStatusText" VerticalAlignment="Bottom" Opacity="0.7"
                               Margin="12,0,0,0" Padding="0,0,0,6" />
                </StackPanel>
            </Border>

            <ListView x:Name="DisposalsList" SelectionMode="None" IsItemClickEnabled="False">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Asset" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Quantity" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Proceeds" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Cost" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Gain/Loss" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Rule" FontWeight="SemiBold" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" />
                            <TextBlock Grid.Column="1" Text="{Binding Asset}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="{Binding QuantityFormatted}" />
                            <TextBlock Grid.Column="3" Text="{Binding ProceedsFormatted}" />
                            <TextBlock Grid.Column="4" Text="{Binding CostFormatted}" />
                            <TextBlock Grid.Column="5" Text="{Binding GainFormatted}" Foreground="{Binding GainColor}" />
                            <TextBlock Grid.Column="6" Text="{Binding MatchingRule}" Opacity="0.7" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
