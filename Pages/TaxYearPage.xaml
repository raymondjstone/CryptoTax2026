<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.TaxYearPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="1000" HorizontalAlignment="Left">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TaxYearTitle" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="TaxYearDateRange" Opacity="0.7" />
                </StackPanel>

                <!-- Export buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <CheckBox x:Name="IncludeKrakenData" Content="Include Kraken trades" IsChecked="True" VerticalAlignment="Center" />
                    <DropDownButton Content="Export">
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Export to Excel (.xlsx)" Click="ExportExcel_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9F9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export to PDF" Click="ExportPdf_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xEA90;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export to Word (.docx)" Click="ExportWord_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A5;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Export ALL Tax Years to Excel" Click="ExportAllExcel_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8B7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </Grid>
            <InfoBar x:Name="ExportInfoBar" IsOpen="False" />

            <!-- User Input Section -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Your Details for This Tax Year" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Enter your taxable employment/self-employment income and any other capital gains (non-crypto) for this tax year."
                               TextWrapping="Wrap" Opacity="0.7" />

                    <NumberBox x:Name="TaxableIncomeBox" Header="Taxable Income (employment, self-employment, pensions etc.)"
                               PlaceholderText="e.g. 45000" SpinButtonPlacementMode="Compact"
                               Minimum="0" SmallChange="1000" LargeChange="10000"
                               ValueChanged="TaxableIncome_ValueChanged"
                               Width="350" HorizontalAlignment="Left" />

                    <NumberBox x:Name="OtherGainsBox" Header="Other Capital Gains (non-crypto, e.g. shares, property)"
                               PlaceholderText="e.g. 0" SpinButtonPlacementMode="Compact"
                               Minimum="0" SmallChange="100" LargeChange="1000"
                               ValueChanged="OtherGains_ValueChanged"
                               Width="350" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- CGT Summary -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Capital Gains Tax Summary" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid ColumnSpacing="20" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition /><RowDefinition /><RowDefinition />
                            <RowDefinition /><RowDefinition /><RowDefinition />
                            <RowDefinition /><RowDefinition /><RowDefinition />
                            <RowDefinition /><RowDefinition /><RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Number of disposals" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DisposalCountText" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Text="Total disposal proceeds" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TotalProceedsText" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2" Text="Total allowable costs" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TotalCostsText" FontWeight="SemiBold" />

                        <Border Grid.Row="3" Grid.ColumnSpan="2" Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                        <TextBlock Grid.Row="4" Text="Total gains" />
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TotalGainsText" FontWeight="SemiBold"
                                   Foreground="Green" />

                        <TextBlock Grid.Row="5" Text="Total losses" />
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TotalLossesText" FontWeight="SemiBold"
                                   Foreground="Red" />

                        <TextBlock Grid.Row="6" Text="Net gain/loss" />
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="NetGainText" FontWeight="SemiBold" />

                        <Border Grid.Row="7" Grid.ColumnSpan="2" Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4" />

                        <TextBlock Grid.Row="8" x:Name="AeaLabel" Text="Annual exempt amount" />
                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="AeaText" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="9" Text="Taxable gain (after AEA)" />
                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="TaxableGainText" FontWeight="Bold"
                                   FontSize="16" />

                        <TextBlock Grid.Row="10" x:Name="CgtRatesLabel" Opacity="0.7" />
                        <TextBlock Grid.Row="10" Grid.Column="1" />

                        <TextBlock Grid.Row="11" Text="CAPITAL GAINS TAX DUE" FontWeight="Bold" FontSize="16" />
                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="CgtDueText" FontWeight="Bold"
                                   FontSize="20" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Tax Rates Info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="Tax Rates Applied" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="BasicRateText" Opacity="0.7" />
                    <TextBlock x:Name="HigherRateText" Opacity="0.7" />
                    <TextBlock x:Name="BasicBandText" Opacity="0.7" />
                    <TextBlock x:Name="PersonalAllowanceText" Opacity="0.7" />
                    <TextBlock Text="Rates sourced from HMRC. Crypto assets are taxed as 'other assets' for CGT purposes."
                               Opacity="0.5" TextWrapping="Wrap" Margin="0,8,0,0" FontStyle="Italic" />
                </StackPanel>
            </Border>

            <!-- Disposals Detail -->
            <TextBlock Text="Individual Disposals" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0" />
            <TextBlock Text="Each row is a disposal event matched using HMRC rules (same-day, bed &amp; breakfast 30-day, then Section 104 pool)."
                       TextWrapping="Wrap" Opacity="0.7" />

            <ListView x:Name="DisposalsList" SelectionMode="None" IsItemClickEnabled="False">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="8,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Date" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Asset" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Quantity" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Proceeds" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Cost" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Gain/Loss" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Rule" FontWeight="SemiBold" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DateFormatted}" />
                            <TextBlock Grid.Column="1" Text="{Binding Asset}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="{Binding QuantityFormatted}" />
                            <TextBlock Grid.Column="3" Text="{Binding ProceedsFormatted}" />
                            <TextBlock Grid.Column="4" Text="{Binding CostFormatted}" />
                            <TextBlock Grid.Column="5" Text="{Binding GainFormatted}" Foreground="{Binding GainColor}" />
                            <TextBlock Grid.Column="6" Text="{Binding MatchingRule}" Opacity="0.7" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
