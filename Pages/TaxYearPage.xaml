                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition />
                                <RowDefinition /><RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Box 3 — Number of disposals" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="Sa108DisposalCount" FontWeight="SemiBold" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="1" Text="Box 4 — Disposal proceeds" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="Sa108Proceeds" FontWeight="SemiBold" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="2" Text="Box 5 — Allowable costs" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="Sa108Costs" FontWeight="SemiBold" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="3" Text="Box 6 — Gains in the year" />
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="Sa108Gains" FontWeight="SemiBold" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="4" Text="Box 7 — Losses in the year" />
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="Sa108Losses" FontWeight="SemiBold" IsTextSelectionEnabled="True" />
                            <TextBlock Grid.Row="5" Text="Box 8 — Losses brought forward and used" />
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="Sa108LossesUsed" FontWeight="SemiBold" IsTextSelectionEnabled="True" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bed & Breakfast Report -->
            <Border x:Name="BnbPanel" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <!-- Panel header (always visible) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bed &amp; Breakfast Matched Disposals" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                        <Button x:Name="BnbCollapseBtn" Grid.Column="1" Content="▲" Click="BnbCollapse_Click" Padding="8,4" />
                    </Grid>
                    <!-- Collapsible content -->
                    <StackPanel x:Name="BnbContent" Spacing="8">
                        <TextBlock Text="These disposals were matched to reacquisitions within 30 days under the B&amp;B rule (TCGA 1992 s106A). HMRC may query these — ensure supporting records are available."
                                   TextWrapping="Wrap" Opacity="0.7" />
                        <TextBlock x:Name="BnbCountText" FontWeight="SemiBold" />
                        <!-- Asset filter -->
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="6" Padding="12">
