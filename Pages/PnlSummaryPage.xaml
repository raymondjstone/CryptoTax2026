<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.PnlSummaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="1100" HorizontalAlignment="Left">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="P&amp;L Summary" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Year-over-year portfolio performance across all tax years" Opacity="0.7" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <DropDownButton Content="Export">
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Export to Excel (.xlsx)" Click="ExportExcel_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9F9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export to PDF" Click="ExportPdf_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xEA90;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </Grid>
            <InfoBar x:Name="ExportInfoBar" IsOpen="False" />

            <!-- P&L sections will be added dynamically -->
            <StackPanel x:Name="PnlContainer" Spacing="16" />

        </StackPanel>
    </ScrollViewer>
</Page>
