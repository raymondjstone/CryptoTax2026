<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoTax2026.Pages.PnlSummaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,0,20,0">
        <StackPanel Spacing="16" MaxWidth="1100" HorizontalAlignment="Left">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="P&amp;L Summary" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Year-over-year portfolio performance across all tax years" Opacity="0.7" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <DropDownButton Content="Export">
                        <DropDownButton.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Export to Excel (.xlsx)" Click="ExportExcel_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9F9;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Export to PDF" Click="ExportPdf_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xEA90;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </Grid>
            <InfoBar x:Name="ExportInfoBar" IsOpen="False" />

            <!-- Year-over-year comparison table -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Year-over-Year Comparison" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid x:Name="ComparisonGrid" ColumnSpacing="16" RowSpacing="4" />
                </StackPanel>
            </Border>

            <!-- Amended return diff -->
            <Border x:Name="AmendedDiffPanel" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource SystemFillColorCautionBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Amended Return Diff" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Shows changes if you recalculate after modifying cost overrides, delisted assets, or manual entries."
                               Opacity="0.7" TextWrapping="Wrap" />
                    <Grid x:Name="AmendedDiffGrid" ColumnSpacing="16" RowSpacing="4" />
                </StackPanel>
            </Border>

            <!-- Monthly CGT accrual -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Monthly Gain/Loss Breakdown" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Shows cumulative gains and losses month by month across all tax years."
                               Opacity="0.7" TextWrapping="Wrap" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <Grid x:Name="MonthlyAccrualGrid" ColumnSpacing="4" RowSpacing="4" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- P&L sections will be added dynamically -->
            <StackPanel x:Name="PnlContainer" Spacing="16" />

        </StackPanel>
    </ScrollViewer>
</Page>
